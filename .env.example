# ClaudeInLove Configuration
# Copy this to .env and fill in your values

# ===========================================
# LLM PROVIDER (Required)
# ===========================================
# Options: "openrouter" (free) or "chatgpt" (browser automation)
LLM_PROVIDER=openrouter

# OpenRouter - get free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Models: deepseek-r1, qwen3, gemini-flash, llama-3.3
OPENROUTER_MODEL=deepseek-r1

# ===========================================
# PLATFORM SETTINGS
# ===========================================
SIGNAL_DEBUG_PORT=9222
BROWSER_HEADLESS=false

# ===========================================
# SAFETY & BEHAVIOR
# ===========================================
SUSPICION_THRESHOLD=0.7
AUTO_PAUSE_ON_FLAG=true
MIN_RESPONSE_DELAY=30
MAX_RESPONSE_DELAY=180

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO

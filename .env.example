# ClaudeInLove configuration — copy to .env and adjust as needed.
# All values below are optional; the defaults shown are what the app uses
# when the variable is unset (see src/core/config.py).

# --- Signal Desktop ---
# Remote-debugging port that Signal Desktop is launched with.
SIGNAL_DEBUG_PORT=9222

# --- Browser automation ---
# Run the automation browser without a visible window ("true"/"false").
BROWSER_HEADLESS=false

# --- Safety ---
# Responses scoring at or above this value (0.0-1.0) are flagged for review.
SUSPICION_THRESHOLD=0.7
# When a response is flagged, pause the conversation for human review.
AUTO_PAUSE_ON_FLAG=true

# --- Human-like response pacing (seconds) ---
MIN_RESPONSE_DELAY=30
MAX_RESPONSE_DELAY=180

# --- Logging ---
# One of: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# --- Paths (optional overrides) ---
# Defaults live under the project directory; override to relocate state.
# DATA_DIR=./data
# LOG_DIR=./logs
# BROWSER_USER_DATA_DIR=./data/browser_profile
